# Where Express runs (Next rewrites /api/* here — server-side only, not exposed to browser)
BACKEND_URL=http://127.0.0.1:5000

# Only set when UI and API are on different public URLs (e.g. Vercel + Railway).
# Leave unset for local dev so requests use same-origin /api (rewrites).
# NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
